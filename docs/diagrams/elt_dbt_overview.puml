@startuml elt_dbt_overview
!theme plain
title Pipeline ELT con dbt-duckdb — Bicis BA (Medallion RAW → STG → MART)

skinparam rectangle {
  RoundCorner 12
  FontSize 13
  BackgroundColor<<bronze>> #CD7F32
  FontColor<<bronze>> white
  BackgroundColor<<silver>> #BFBFBF
  BackgroundColor<<gold>> #F2C14E
  BackgroundColor<<src>> #E8E8E8
  BackgroundColor<<sink>> #D6EAF8
  BackgroundColor<<tool>> #FFF2CC
}
skinparam ArrowFontSize 11
skinparam shadowing false

' ---------- Origen ----------
package "Origen — data.buenosaires.gob.ar" {
  rectangle "trips_2022.csv"                              as src_rec22 <<src>>
  rectangle "trips_2023.csv"                              as src_rec23 <<src>>
  rectangle "badata_ecobici_recorridos_realizados_2024.csv" as src_rec24 <<src>>
  rectangle "usuarios_ecobici_2022.csv"                   as src_usr22 <<src>>
  rectangle "usuarios_ecobici_2023.csv"                   as src_usr23 <<src>>
  rectangle "usuarios_ecobici_2024.csv"                   as src_usr24 <<src>>
}

' ---------- Lakehouse ----------
package "Data Lakehouse — Parquet" {

  package "RAW · Bronze\nespejo 1:1 del CSV — 1 parquet por archivo (sin merge cross-year)" {
    rectangle "raw_recorridos_2022" as raw_rec22 <<bronze>>
    rectangle "raw_recorridos_2023" as raw_rec23 <<bronze>>
    rectangle "raw_recorridos_2024" as raw_rec24 <<bronze>>
    rectangle "raw_usuarios_2022"   as raw_usr22 <<bronze>>
    rectangle "raw_usuarios_2023"   as raw_usr23 <<bronze>>
    rectangle "raw_usuarios_2024"   as raw_usr24 <<bronze>>
  }

  package "STG · Silver\nUNION cross-year + limpieza + normalización" {
    rectangle "stg_recorridos\n• union 2022-2024\n• tipos\n• timestamps UTC\n• dedup" as stg_rec <<silver>>
    rectangle "stg_usuarios\n• union 2022-2024\n• edad/género normalizados" as stg_usr <<silver>>
  }

  package "MART · Gold" {
    rectangle "MART_BI (modelo estrella)" as mart_bi <<gold>> {
      rectangle "fct_recorridos" as fct
      rectangle "dim_usuario"    as dim_usr
      rectangle "dim_tiempo"     as dim_t
    }
    rectangle "MART_ML\nfeatures_recorridos\n(input + target:\np.ej. duración / demanda)" as mart_ml <<gold>>
  }
}

' ---------- Consumo ----------
rectangle "Dashboard BI\nLooker Studio / PowerBI" as bi <<sink>>
rectangle "Modelo ML\nscikit-learn" as ml <<sink>>

' ---------- dbt-duckdb ----------
package "dbt-duckdb project" as dbtproj <<tool>> {
  rectangle "models/\nstaging · marts" as dbt_models
  rectangle "tests/\nnot_null · unique\naccepted_values · relationships" as dbt_tests
  rectangle "sources.yml\nseeds/ · macros/" as dbt_sources
  rectangle "docs/\nlineage + catálogo" as dbt_docs
}

' ---------- Flujo principal ----------
src_rec22 --> raw_rec22 : EL\n(read_csv)
src_rec23 --> raw_rec23 : EL
src_rec24 --> raw_rec24 : EL
src_usr22 --> raw_usr22 : EL
src_usr23 --> raw_usr23 : EL
src_usr24 --> raw_usr24 : EL

raw_rec22 --> stg_rec : union all
raw_rec23 --> stg_rec : union all
raw_rec24 --> stg_rec : union all
raw_usr22 --> stg_usr : union all
raw_usr23 --> stg_usr : union all
raw_usr24 --> stg_usr : union all

stg_rec --> fct
stg_usr --> dim_usr
stg_rec --> dim_t   : derivado

stg_rec --> mart_ml
stg_usr --> mart_ml

mart_bi --> bi : parquet
mart_ml --> ml : parquet

' ---------- dbt como capa transversal ----------
dbt_sources ..> raw_rec22 : declara
dbt_models  ..> stg_rec   : materializa
dbt_models  ..> mart_bi   : materializa
dbt_models  ..> mart_ml   : materializa
dbt_tests   ..> stg_rec   : valida
dbt_tests   ..> mart_bi   : valida
dbt_tests   ..> mart_ml   : valida

note bottom of dbt_tests
  Métricas de calidad
  (≥ 2 con umbrales)
  + validación cruzada
  vs. equipo Python
end note

@enduml
